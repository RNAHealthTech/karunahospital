  align-items: center;
  gap: 0.6rem;
  background: var(--brand-accent);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  padding: 0.95rem 2rem;
  border-radius: 0.875rem;
  text-decoration: none;
  box-shadow: 0 8px 24px rgba(232, 86, 58, 0.4);
  transition:
    background 0.2s,
    transform 0.2s,
    box-shadow 0.2s;
}
.dp-btn-primary:hover {
  background: var(--brand-accent-dark);
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(232, 86, 58, 0.5);
}
.dp-btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  background: rgba(255, 255, 255, 0.1);
  border: 1.5px solid rgba(255, 255, 255, 0.25);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  padding: 0.95rem 2rem;
  border-radius: 0.875rem;
  text-decoration: none;
  transition: background 0.2s;
}
.dp-btn-ghost:hover {
  background: rgba(255, 255, 255, 0.18);
}

/* -- Body -- */
.dp-body {
  background: var(--neutral-50);
  padding: 8rem 0 10rem;
}
.dp-body__inner {
  max-width: 1320px;
  margin: 0 auto;
  padding: 0 2.5rem;
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 5rem;
  align-items: start;
}
.dp-main {
  display: flex;
  flex-direction: column;
  gap: 3.5rem;
}

/* Cards */
.dp-card {
  background: #fff;
  border: 1px solid var(--neutral-200);
  border-radius: 2rem;
  padding: 3.5rem;
  transition:
    box-shadow 0.3s,
    transform 0.3s;
}
.dp-card:hover {
  box-shadow: 0 12px 48px rgba(11, 111, 164, 0.12);
  transform: translateY(-2px);
}
.dp-card__head {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--neutral-100);
  margin-bottom: 1.75rem;
}
.dp-card__icon {
  width: 50px;
  height: 50px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.dp-card__icon--blue {
  background: #dbeafe;
  color: #2563eb;
}
.dp-card__icon--orange {
  background: #ffedd5;
  color: #ea580c;
}
.dp-card__icon--rose {
  background: #fce7f3;
  color: #be185d;
}
.dp-card__icon--indigo {
  background: #e0e7ff;
  color: #4f46e5;
}
.dp-card__title {
  font-family: "Playfair Display", serif;
  font-size: 1.45rem;
  font-weight: 700;
  color: var(--neutral-900);
}
.dp-card__text {
  font-size: 1rem;
  color: var(--neutral-600);
  line-height: 1.85;
}

/* List */
.dp-list {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}
.dp-list-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: var(--neutral-50);
  border: 1px solid var(--neutral-100);
  border-radius: 1rem;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--neutral-700);
  transition:
    background 0.2s,
    border-color 0.2s;
}
.dp-list-item:hover {
  background: #f0f4f8;
  border-color: #c4cfdc;
}
.dp-list-item__dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--brand-primary);
  flex-shrink: 0;
}
.dp-list-item__award {
  color: var(--brand-primary);
  flex-shrink: 0;
}

/* Tags */
.dp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}
.dp-tag {
  padding: 0.55rem 1.25rem;
  background: var(--brand-primary-light);
  color: var(--brand-primary);
  border: 1px solid rgba(11, 111, 164, 0.15);
  border-radius: 100px;
  font-size: 0.875rem;
  font-weight: 600;
  transition:
    background 0.2s,
    transform 0.2s;
}
.dp-tag:hover {
  background: #d1e8f7;
  transform: translateY(-1px);
}

/* Sidebar */
.dp-sidebar {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  position: sticky;
  top: 130px;
}
.dp-sidebar-card {
  background: #fff;
  border: 1px solid var(--neutral-200);
  border-radius: 1.5rem;
  padding: 2rem;
  box-shadow: 0 4px 24px rgba(11, 111, 164, 0.07);
}
.dp-sidebar-card__title {
  font-family: "Playfair Display", serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--brand-primary-dark);
  margin-bottom: 0.35rem;
}
.dp-sidebar-card__sub {
  font-size: 0.9rem;
  color: var(--neutral-600);
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--neutral-100);
  margin-bottom: 1.5rem;
  line-height: 1.55;
}
.dp-sidebar-card__rows {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 1.75rem;
}
.dp-sidebar-card__row {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.dp-sidebar-card__row-icon {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--brand-primary-light);
  color: var(--brand-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 0.2rem;
}
.dp-sidebar-card__lbl {
  display: block;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--neutral-600);
  margin-bottom: 0.2rem;
}
.dp-sidebar-card__val {
  display: block;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--neutral-900);
  text-decoration: none;
  line-height: 1.35;
}
a.dp-sidebar-card__val:hover {
  color: var(--brand-primary);
}
.dp-sidebar-card__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.65rem;
  width: 100%;
  padding: 1rem;
  background: linear-gradient(
    135deg,
    var(--brand-primary),
    var(--brand-primary-dark)
  );
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  border-radius: 1rem;
  text-decoration: none;
  box-shadow: 0 8px 24px rgba(11, 111, 164, 0.35);
  transition:
    transform 0.2s,
    box-shadow 0.2s;
}
.dp-sidebar-card__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(11, 111, 164, 0.45);
}

/* Dark card */
.dp-sidebar-card--dark {
  background: var(--neutral-900);
  border-color: rgba(255, 255, 255, 0.06);
}
.dp-dark-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
  border: 1px solid rgba(251, 191, 36, 0.3);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  font-size: 0.76rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 1.25rem;
}
.dp-dark-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  list-style: none;
  padding: 0;
}
.dp-dark-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.45;
}
.dp-dark-list-icon {
  color: #4ade80;
  flex-shrink: 0;
  margin-top: 2px;
}

/* Speciality Nav */
.spec-nav-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.spec-nav-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1.25rem;
  border-radius: 0.75rem;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--neutral-600);
  text-decoration: none;
  background: transparent;
  border: 1px solid transparent;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.spec-nav-item:hover {
  background: var(--neutral-50);
  color: var(--brand-primary);
  border-color: var(--neutral-100);
  transform: translateX(4px);
}
.spec-nav-item--active {
  background: var(--brand-primary-light);
  color: var(--brand-primary);
  border-color: rgba(11, 111, 164, 0.1);
  box-shadow: 0 4px 12px rgba(11, 111, 164, 0.05);
}
.spec-nav-item__arrow {
  opacity: 0;
  transform: translateX(-10px);
  transition: all 0.25s;
}
.spec-nav-item:hover .spec-nav-item__arrow,
.spec-nav-item--active .spec-nav-item__arrow {
  opacity: 1;
  transform: translateX(0);
}

/* Check List */
.check-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.check-list-item {
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  font-size: 1rem;
  color: var(--neutral-700);
  line-height: 1.5;
}
.check-list-icon {
  width: 20px;
  height: 20px;
  background: var(--brand-primary-light);
  color: var(--brand-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 0.1rem;
  font-size: 10px;
}

/* CTA Banner */
.dp-cta-banner {
  background: #fff;
  border-top: 1px solid var(--neutral-200);
  padding: 5rem 0;
}
.dp-cta-banner__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2.5rem;
}
.dp-cta-banner__box {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  background: linear-gradient(135deg, #0b2a47 0%, var(--brand-primary) 100%);
  padding: 3.5rem 4rem;
  border-radius: 2rem;
  box-shadow: 0 24px 64px rgba(11, 111, 164, 0.2);
}
.dp-cta-banner__copy h3 {
  font-family: "Playfair Display", serif;
  font-size: 2rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.5rem;
}
.dp-cta-banner__copy p {
  font-size: 1.05rem;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.65;
}
.dp-cta-banner__actions {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  flex-shrink: 0;
}
.dp-cta-phone {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 700;
  font-size: 1.15rem;
  text-decoration: none;
  transition: color 0.2s;
}
.dp-cta-phone:hover {
  color: #fff;
}

/* Responsive */
@media (max-width: 1100px) {
  .dp-hero__layout {
    grid-template-columns: 240px 1fr;
    gap: 2.5rem;
  }
  .dp-body__inner {
    grid-template-columns: 1fr 340px;
  }
}
@media (max-width: 900px) {
  .dp-hero {
    padding: 2.5rem 0 4rem;
  }
  .dp-hero__layout {
    grid-template-columns: 1fr;
    gap: 3rem;
    text-align: center;
  }
  .dp-portrait {
    max-width: 240px;
    margin: 0 auto;
  }
  .dp-info__tagline {
    margin-left: auto;
    margin-right: auto;
  }
  .dp-info__dept {
    margin: 0 auto 1.25rem;
  }
  .dp-stats {
    justify-content: center;
  }
  .dp-cta {
    justify-content: center;
  }
  .dp-body__inner {
    grid-template-columns: 1fr;
  }
  .dp-sidebar {
    position: static;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .dp-cta-banner__box {
    flex-direction: column;
    text-align: center;
    padding: 2.5rem;
  }
  .dp-cta-banner__actions {
    flex-direction: column;
    width: 100%;
  }
}
@media (max-width: 600px) {
  .dp-hero__inner {
    padding: 0 1.25rem;
  }
  .dp-body__inner {
    padding: 0 1.25rem;
  }
  .dp-cta-banner__inner {
    padding: 0 1.25rem;
  }
  .dp-sidebar {
    display: flex;
  }
  .dp-cta-banner__box {
    border-radius: 1.25rem;
    padding: 2rem;
  }
  .dp-cta-banner__copy h3 {
    font-size: 1.5rem;
  }
}

/* 
   PREMIUM GLOBAL COMPONENTS (Used across pages)
 */

/*  Premium Hero  */
.premium-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(
    135deg,
    #0b2a47 0%,
    var(--brand-primary) 55%,
    #1a9fd4 100%
  );
  padding: 6rem 0 7rem;
}
.premium-hero--compact {
  padding: 4rem 0 5rem;
}
.premium-hero__pattern {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}
.premium-hero__glow {
  position: absolute;
  top: -150px;
  right: -150px;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 255, 255, 0.08) 0%,
    transparent 70%
  );
  pointer-events: none;
}
.premium-hero__glow--left {
  right: auto;
  left: -150px;
  bottom: -150px;
  top: auto;
}
.premium-hero__inner {
  position: relative;
  z-index: 2;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2.5rem;
  text-align: center;
}
.premium-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(251, 191, 36, 0.18);
  border: 1px solid rgba(251, 191, 36, 0.35);
  color: #fde68a;
  padding: 0.5rem 1.25rem;
  border-radius: 100px;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0 auto 1.5rem;
}
.premium-hero__title {
  font-family: "Playfair Display", serif;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: 1.25rem;
}
.premium-hero__subtitle {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.75;
  max-width: 700px;
  margin: 0 auto 2.5rem;
}

/*  Premium CTA Layout  */
.premium-cta-section {
  background: #fff;
  border-top: 1px solid var(--neutral-200);
  padding: 6rem 0;
}
.premium-cta-section__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2.5rem;
}
.premium-cta-box {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 2.5rem;
  background: linear-gradient(135deg, #0b2a47 0%, var(--brand-primary) 100%);
  padding: 4rem 5rem;
  border-radius: 2rem;
  box-shadow: 0 24px 64px rgba(11, 111, 164, 0.2);
}
.premium-cta-box__left h3 {
  font-family: "Playfair Display", serif;
  font-size: 2.5rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.75rem;
  line-height: 1.2;
}
.premium-cta-box__left p {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.65;
  max-width: 600px;
}
.premium-cta-box__actions {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  flex-shrink: 0;
}

/*  Premium Content Area  */
.premium-section {
  padding: 6rem 0;
  background: var(--neutral-50);
}
.premium-section__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2.5rem;
}

@media (max-width: 900px) {
  .premium-hero {
    padding: 4rem 0 5rem;
  }
  .premium-hero__inner,
  .premium-section__inner,
  .premium-cta-section__inner {
    padding: 0 1.5rem;
  }
  .premium-cta-box {
    flex-direction: column;
    text-align: center;
    padding: 2.5rem;
  }
  .premium-cta-box__actions {
    flex-direction: column;
    width: 100%;
  }
  .premium-cta-box__actions a {
    width: 100%;
    justify-content: center;
  }
}
