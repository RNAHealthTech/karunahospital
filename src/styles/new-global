  background: radial-gradient(
    circle,
    rgba(255, 255, 255, 0.08) 0%,
    transparent 70%
  );
  pointer-events: none;
}
.dp-hero__inner {
  position: relative;
  z-index: 2;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2.5rem;
}
.dp-hero__back {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: rgba(255, 255, 255, 0.75);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 2.5rem;
  transition: color 0.2s;
}
.dp-hero__back:hover {
  color: #fff;
}
.dp-hero__layout {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 6rem;
  align-items: center;
}

/* Portrait */
.dp-portrait {
  position: relative;
}
.dp-portrait__frame {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 1.5rem;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.1);
  border: 5px solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 32px 80px rgba(0, 0, 0, 0.35);
}
.dp-portrait__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}
.dp-portrait__frame:hover .dp-portrait__img {
  transform: scale(1.04);
}
.dp-portrait__fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.3);
}
.dp-portrait__badge {
  position: absolute;
  bottom: -1.2rem;
  left: 50%;
  transform: translateX(-50%);
